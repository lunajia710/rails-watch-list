<% @banner_image = list_cover_image(@list) %>
<% @banner_title = @list.name %>
<% @banner_subtitle = pluralize(@list.movies.count, "movie") %>

<div class="d-flex justify-content-between">
  <h1 class="m-4">
    <%= @list.name %> (<%= @list.movies.count %>)
  </h1>
  <%= link_to "add a movie", new_list_bookmark_path(@list), class: "btn btn-success m-4" %>
</div>

<% @list.bookmarks.each do |bookmark| %>
  <div class="container d-flex m-4">
    <div class="row">
      <div class="col-12 col-md-6 movie-card">
        <div class="movie-card-poster">
          <%= image_tag bookmark.movie.poster_url.presence || "movie-icon.svg", alt: bookmark.movie.title %>
        </div>
        <div class="movie-card-body">
          <h2 class="movie-card-title"><%= bookmark.movie.title %></h2>
          <div class="movie-card-rating"><%= star_rating(bookmark.movie.rating) %></div>
          <p class="movie-card-overview"><%= truncate(bookmark.movie.overview, length: 220) %></p>
          <% if bookmark.comment.present? %>
            <p class="movie-card-comment">"<%= bookmark.comment %>"</p>
          <% end %>
          <%=
            link_to "delete", bookmark_path(bookmark),
            class: "btn btn-outline-danger",
            data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}
          %>
        </div>
      </div>
    </div>
  </div>
<% end %>
<div class="d-flex justify-content-end">
  <%= link_to "Back to home", lists_path, class: "btn btn-primary m-4" %>
</div>
